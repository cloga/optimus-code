{
  "version": 1,
  "servers": {
    "spartan-swarm": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${workspaceRoot}/.optimus/dist/mcp-server.js"
      ],
      "env": {
        "OPTIMUS_WORKSPACE_ROOT": "${workspaceRoot}",
        "DOTENV_PATH": "${workspaceRoot}/.env"
      },
      "clients": {
        "vscode": {
          "env": {
            "PATH": "${env:PATH}"
          }
        }
      }
    }
  }
}
