{
  "$schema": "./available-agents.schema.json",
  "_schema_version": 1,
  "_comment": "T3 Engine & Model resource pool. All engines use ACP protocol with warm pool for persistent sessions and autopilot mode. CLI adapters are deprecated since v2.16.8.",
  "engines": {
    "claude-code": {
      "protocol": "acp",
      "available_models": ["claude-opus-4.6-1m", "gpt-5.4", "gemini-3-pro-preview"],
      "cli_flags": "--model",
      "timeout": { "heartbeat_ms": 600000, "activity_ms": 1200000 },
      "automation": { "mode": "auto-approve", "continuation": "autopilot", "max_continues": 8 },
      "acp": {
        "path": "claude-agent-acp",
        "cli_flags": "--model",
        "capabilities": { "automation_modes": ["auto-approve"], "automation_continuations": ["single", "autopilot"] }
      },
      "_comment": "ACP-only with autopilot. Warm pool reuses persistent claude-agent-acp process."
    },
    "github-copilot": {
      "protocol": "acp",
      "available_models": ["gemini-3-pro-preview", "gpt-5.4", "claude-opus-4.6-1m"],
      "automation": { "mode": "auto-approve", "continuation": "autopilot", "max_continues": 8 },
      "timeout": { "heartbeat_ms": 600000 },
      "acp": {
        "path": "copilot",
        "args": ["--acp"],
        "capabilities": { "automation_modes": ["auto-approve"], "automation_continuations": ["single", "autopilot"] }
      },
      "_comment": "ACP-only with autopilot. Warm pool reuses persistent copilot --acp process. Autopilot configured via AcpAdapter.configureSession()."
    },
    "qwen-code": {
      "protocol": "acp",
      "path": "auto",
      "args": ["--acp"],
      "available_models": ["qwen3-coder"],
      "cli_flags": "--model",
      "_comment": "path 'auto' = auto-discover Qwen Code CLI from VS Code extensions. Install the Qwen Code extension first."
    }
  }
}