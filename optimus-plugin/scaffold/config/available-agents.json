{
  "$schema": "./available-agents.schema.json",
  "_schema_version": 1,
  "_comment": "Engine & Model configuration. ACP protocol, warm pool, and autopilot mode are system defaults.",
  "engines": {
    "claude-code": {
      "available_models": ["claude-opus-4.6-1m", "gpt-5.4", "gemini-3-pro-preview"],
      "timeout": { "heartbeat_ms": 600000, "activity_ms": 300000 },
      "acp": { "path": "claude-agent-acp" }
    },
    "github-copilot": {
      "available_models": ["gemini-3-pro-preview", "gpt-5.4", "claude-opus-4.6-1m"],
      "timeout": { "heartbeat_ms": 600000 },
      "acp": { "path": "copilot", "args": ["--acp", "--stdio"] }
    },
    "qwen-code": {
      "available_models": ["qwen3-coder"],
      "timeout": { "heartbeat_ms": 600000, "activity_ms": 300000 },
      "acp": { "path": "auto", "args": ["--acp"] },
      "_comment": "path 'auto' = auto-discover from VS Code extensions"
    }
  }
}
