{
  "_comment": "Configure your VCS provider. Set provider to 'auto-detect', 'github', or 'azure-devops'.",
  "provider": "auto-detect",
  "github": {
    "auth": "env:GITHUB_TOKEN",
    "owner": "",
    "repo": ""
  },
  "ado": {
    "auth": "env:ADO_PAT",
    "organization": "",
    "project": "",
    "defaults": {
      "work_item_type": "Task",
      "auto_tags": [
        "created-by:optimus-code"
      ]
    }
  },
  "pre_merge_build": {
    "enabled": false,
    "command": "npm run build",
    "cwd": "."
  }
}
