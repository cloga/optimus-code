{
  "name": "@cloga/optimus-swarm-mcp",
  "version": "2.16.18",
  "description": "Spartan Swarm Orchestrator — a universal multi-agent MCP plugin",
  "main": "dist/mcp-server.js",
  "bin": {
    "optimus": "bin/cli.js"
  },
  "type": "commonjs",
  "scripts": {
    "build": "node esbuild.plugin.js",
    "build:production": "node esbuild.plugin.js --production",
    "prepublishOnly": "npm run build:production",
    "postinstall": "node scripts/postinstall.js"
  },
  "files": [
    "dist/",
    "bin/",
    "roles/",
    "agents/",
    "skills/",
    "scaffold/",
    "scripts/postinstall.js",
    ".mcp.json",
    ".claude-plugin/"
  ],
  "keywords": [
    "mcp",
    "multi-agent",
    "swarm",
    "orchestrator",
    "ai-agents"
  ],
  "license": "MIT",
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^16.4.5",
    "esbuild": "^0.25.0",
    "iconv-lite": "^0.6.3",
    "strip-ansi": "7.2.0",
    "typescript": "^5.8.2"
  }
}
