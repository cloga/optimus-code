{
  "name": "optimus-code",
  "displayName": "Optimus Code",
  "description": "The Ultimate Multi-Agent Orchestrator",
  "version": "0.0.8",
  "publisher": "Trinity-Alpha",
  "repository": {
    "type": "git",
    "url": "https://github.com/cloga/optimus-code.git"
  },
  "scripts": {
    "compile": "tsc --noEmit",
    "watch": "npm-run-all -p watch:*",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "check-types": "tsc --noEmit",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "prepare": "cd optimus-plugin && npm install && npm run build:production"
  },
  "devDependencies": {
    "@types/marked": "^5.0.2",
    "@types/node": "18.x",
    "@types/strip-ansi": "^3.0.0",
    "esbuild": "^0.25.12",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^16.3.1",
    "iconv-lite": "^0.6.3",
    "marked": "^17.0.4",
    "strip-ansi": "^7.2.0"
  },
  "main": "optimus-plugin/dist/mcp-server.js",
  "bin": {
    "optimus": "./optimus-plugin/bin/cli.js"
  }
}
